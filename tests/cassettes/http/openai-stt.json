          "required_fields": ["file", "model"]
        }
      },
      "response": {
        "status": 200,
        "headers": {
          "content-type": "application/json",
          "x-request-id": "[REDACTED_REQUEST_ID]"
        },
        "json": {
          "text": "hello world"
        }
      }
    }
  ]
}

