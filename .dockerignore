# Keep the build context small and predictable.
.git/
.github/

# Python build artefacts
**/__pycache__/
**/*.pyc
**/*.pyo
**/*.egg-info/
.venv/
dist/
build/

# Tooling caches
.mypy_cache/
.pytest_cache/
.ruff_cache/
.easycat/

# Not needed inside the image
tests/
perf/
plan/
docs/

# Local dev config
.pre-commit-config.yaml
.python-version
